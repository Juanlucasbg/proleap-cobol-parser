{
  "name": "saleads-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright E2E tests for SaleADS workflows.",
  "type": "module",
  "scripts": {
    "install:browsers": "playwright install --with-deps chromium",
